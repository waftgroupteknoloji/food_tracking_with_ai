{
  "expo": {
    "name": "Yemek Takip",
    "slug": "yemek-takip",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "yemektakip",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yemektakip.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "package": "com.yemektakip.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Yemek fotoğrafı yüklemek için galeri izni gerekiyor.",
          "cameraPermission": "Yemek fotoğrafı çekmek için kamera izni gerekiyor."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://diyet-kappa.vercel.app",
      "router": {},
      "eas": {
        "projectId": "b92453d7-0466-463c-b778-f32cf40905fd"
      }
    }
  }
}
