# ============================================
# Backend (apps/web)
# ============================================

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Database → Connect → Drivers (Node.js)
MONGODB_URI=

# JWT secrets — generate with: openssl rand -base64 64
# PREVIOUS is used during secret rotation, can be same as CURRENT initially
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=

# Cookie domain — leave empty in dev (localhost), set to your domain in prod (e.g. .yemek-takip.com)
COOKIE_DOMAIN=

# ============================================
# AI — Google Gemini
# ============================================
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ============================================
# AWS S3 (image storage)
# ============================================
# IAM user with PutObject/GetObject/DeleteObject permissions on the bucket
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Public base URL for served assets, e.g. https://your-bucket.s3.eu-central-1.amazonaws.com
# (or your CloudFront distribution URL)
S3_PUBLIC_BASE_URL=

# ============================================
# Ödematik (payment / billing)
# ============================================
# Merchant API key from your ödematik dashboard (Settings → API).
# Format: wk_<60 hex chars>. NEVER expose to the browser.
ODEMATIK_API_KEY=

# Optional: defaults to https://api.odematik.com (production). Only set
# this if you're running ödematik backend locally or in staging.
# ODEMATIK_API_BASE=http://localhost:4000

# Optional: shared secret for the webhook receiver mounted at
# /api/odematik/webhook. Configure on the ödematik dashboard under
# "Webhook Endpoints", then paste the secret here. Without this the
# /webhook endpoint refuses all calls.
# ODEMATIK_WEBHOOK_SECRET=

# ============================================
# Public (mobil ve client-side)
# ============================================
# Used by Expo mobile app to know where the backend is.
# For physical device: replace localhost with your computer's LAN IP (e.g. http://192.168.1.10:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000
